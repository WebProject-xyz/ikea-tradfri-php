{
  "name": "webproject-xyz/ikea-tradfri-php-api",
  "description": "PHP library to control ikea tradfri hub",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Benjamin Fahl",
      "email": "ben+github@webproject.xyz",
      "role": "developer"
    }
  ],
  "homepage": "https://www.webproject.xyz",
  "require": {
    "php": "~8.4.0 || ~8.5.0",
    "ext-filter": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "doctrine/collections": "^2.6.0",
    "psr/log": "^3.0.2",
    "roave/better-reflection": "^6.69.0",
    "symfony/polyfill-mbstring": "^1.33.0",
    "symfony/process": "^7.4.5",
    "symfony/property-access": "^7.4.4",
    "symfony/property-info": "^7.4.6",
    "symfony/serializer": "^7.4.6",
    "symfony/service-contracts": "^3.6.1",
    "symfony/validator": "^7.4.6",
    "webmozart/assert": "^2.1.6"
  },
  "require-dev": {
    "codeception/codeception": "^5.3.5",
    "codeception/mockery-module": "^0.5.0",
    "codeception/module-asserts": "^3.3.0",
    "ergebnis/license": "^2.7.0",
    "ergebnis/php-cs-fixer-config": "^6.60.1",
    "friendsofphp/php-cs-fixer": "^3.94.2",
    "mockery/mockery": "^1.6.12",
    "phpro/grumphp": "^2.19.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpdoc-parser": "^2.3.2",
    "phpstan/phpstan": "^2.1.40",
    "phpstan/phpstan-doctrine": "^2.0.18",
    "phpstan/phpstan-mockery": "^2.0.0",
    "phpunit/phpunit": "^13.0.0",
    "rector/rector": "^2.3.8",
    "roave/security-advisories": "dev-latest",
    "symfony/var-dumper": "^7.4.6",
    "wmde/psr-log-test-doubles": "^3.4.0",
    "webproject-xyz/codeception-module-ai-reporter": "^1.0.1"
  },
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "IKEA\\Tradfri\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IKEA\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "phpro/grumphp": true,
      "phpstan/extension-installer": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.4.99"
    }
  },
  "scripts": {
    "build-coverage": [
      "echo 'Build coverage'",
      "XDEBUG_MODE=coverage ./vendor/bin/codecept run --coverage-xml=clover.xml --coverage --xml --colors --report "
    ],
    "cs:check": "php-cs-fixer fix --allow-risky=yes --dry-run --diff --show-progress=dots",
    "cs:fix": "php-cs-fixer fix --allow-risky=yes",
    "php-cs-fixer": "vendor/bin/php-cs-fixer fix -vv --path-mode=intersection",
    "php-cs-fixer-full": "vendor/bin/php-cs-fixer fix -v --show-progress dots",
    "phpstan": "vendor/bin/phpstan analyse --memory-limit=-1  --no-progress --no-ansi",
    "run-tests": [
      "./vendor/bin/codecept run --colors"
    ],
    "stan": "phpstan analyse --memory-limit=-1  --no-progress --debug",
    "test": "codecept run --report",
    "test:build": "codecept build",
    "test:coverage": "XDEBUG_MODE=coverage codecept run --coverage --coverage-xml=coverage.xml --xml  --report"
  }
}
