{
  "name": "webproject-xyz/ikea-tradfri-php-api",
  "description": "PHP library to control ikea tradfri hub",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Benjamin Fahl",
      "email": "ben+github@webproject.xyz",
      "role": "developer"
    }
  ],
  "homepage": "https://www.webproject.xyz",
  "require": {
    "php": "~8.4.0 || ~8.5.0",
    "ext-filter": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "doctrine/collections": "^2.6.0",
    "psr/log": "^3.0.2",
    "symfony/polyfill-mbstring": "^1.37.0",
    "symfony/process": "^8.0.0",
    "symfony/property-access": "^8.0.0",
    "symfony/property-info": "^8.0.0",
    "symfony/serializer": "^8.0.0",
    "symfony/service-contracts": "^3.6.1",
    "symfony/validator": "^8.0.0",
    "webmozart/assert": "^2.3.0"
  },
  "require-dev": {
    "codeception/codeception": "^5.3.5",
    "codeception/mockery-module": "^0.5.0",
    "codeception/module-asserts": "^3.3.0",
    "ergebnis/license": "^2.7.0",
    "ergebnis/php-cs-fixer-config": "^6.61.1",
    "friendsofphp/php-cs-fixer": "^3.95.1",
    "mockery/mockery": "^1.6.12",
    "phpro/grumphp": "^2.20.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpdoc-parser": "^2.3.2",
    "phpstan/phpstan": "^2.1.51",
    "phpstan/phpstan-doctrine": "^2.0.21",
    "phpstan/phpstan-mockery": "^2.0.0",
    "rector/rector": "^2.4.2",
    "roave/security-advisories": "dev-latest",
    "symfony/var-dumper": "^8.0.0",
    "wmde/psr-log-test-doubles": "^3.4.0",
    "webproject-xyz/codeception-module-ai-reporter": "^1.1.1"
  },
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "IKEA\\Tradfri\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IKEA\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "phpro/grumphp": true,
      "phpstan/extension-installer": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.4.99"
    }
  },
  "scripts": {
    "cs:check": "XDEBUG_MODE=off php-cs-fixer fix --allow-risky=yes --dry-run --diff --show-progress=dots",
    "cs:fix": "XDEBUG_MODE=off php-cs-fixer fix --show-progress=none --allow-risky=yes",
    "stan": "XDEBUG_MODE=off phpstan analyse --no-progress --no-ansi --memory-limit=-1",
    "test": "XDEBUG_MODE=off codecept run --report",
    "test:coverage": "XDEBUG_MODE=coverage codecept run --coverage --coverage-xml=coverage.xml --xml  --report",
    "test:build": "XDEBUG_MODE=off codecept build",
    "qa": [
      "@test:build",
      "@cs:fix",
      "@test",
      "@stan"
    ]
  }
}
